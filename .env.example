# ============================================
# 견적서 웹 애플리케이션 환경 변수 예시
# ============================================
# 이 파일을 .env.local로 복사하여 실제 값을 입력하세요:
#   cp .env.example .env.local
#
# 이 파일은 git에 커밋됩니다 (실제 시크릿 값은 절대 입력하지 마세요)

# --------------------------------------------
# Supabase 설정
# 참조: https://app.supabase.com → 프로젝트 → Settings → API
# --------------------------------------------

# Supabase 프로젝트 URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase 익명(anon) 공개 키 - 클라이언트 사이드 사용 안전
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase 서비스 역할 키 - 서버 사이드 전용 (절대 클라이언트에 노출 금지!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --------------------------------------------
# Notion API 설정
# 참조: https://www.notion.so/my-integrations
# --------------------------------------------

# Notion 인테그레이션 Internal Integration Token
# 형식: ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_API_KEY=ntn_your-notion-integration-token-here

# Notion 견적서 데이터베이스 ID
# 데이터베이스 URL: https://notion.so/workspace/[DATABASE_ID]?v=xxx
# DATABASE_ID는 하이픈 없는 32자리 문자열입니다
NOTION_INVOICE_DATABASE_ID=your-32-character-database-id-here

# --------------------------------------------
# 애플리케이션 설정
# --------------------------------------------

# 현재 실행 환경 (development | production | test)
NODE_ENV=development

# 애플리케이션 기본 URL (배포 시 실제 도메인으로 변경)
NEXT_PUBLIC_APP_URL=http://localhost:3000
